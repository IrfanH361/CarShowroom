<%- include('partials/header') %>

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3><i class="fas fa-tag"></i> Sell Your Car</h3>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <% if (user.role === 'seller') { %>
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle"></i>
                        Your car will be submitted for admin approval before appearing on the homepage.
                    </div>
                <% } %>

                <% if (user.role === 'admin') { %>
                    <div class="alert alert-success">
                        <i class="fas fa-check-circle"></i>
                        As an admin, your car will be approved instantly and appear on the homepage immediately.
                    </div>
                <% } %>

                <form action="/sell-car" method="POST" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Car Name</label>
                            <input type="text" name="name" class="form-control" placeholder="e.g. My Dream Civic" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Make</label>
                            <select name="make" class="form-select" required>
                                <option value="">Select Make</option>
                                <option value="Toyota">Toyota</option>
                                <option value="Honda">Honda</option>
                                <option value="BMW">BMW</option>
                                <option value="Mercedes">Mercedes</option>
                                <option value="Audi">Audi</option>
                                <option value="Porsche">Porsche</option>
                                <option value="Ferrari">Ferrari</option>
                                <option value="Lamborghini">Lamborghini</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Model</label>
                            <input type="text" name="model" class="form-control" placeholder="e.g. Civic Type R" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Year</label>
                            <select name="year" class="form-select" required>
                                <option value="">Select Year</option>
                                <% for (let y = 2025; y >= 2000; y--) { %>
                                    <option value="<%= y %>"><%= y %></option>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Color</label>
                            <input type="text" name="color" class="form-control" placeholder="e.g. Red" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price ($)</label>
                            <input type="number" name="price" class="form-control" placeholder="e.g. 45000" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3" placeholder="Tell us about this car..."></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Car Image</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Submit for Sale</button>
                    <a href="/dashboard" class="btn btn-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>