<%- include('partials/header') %>

<div class="row">
    <div class="col-md-12">
        <a
            href="javascript:history.back()"
            class="btn btn-secondary mb-3"
        >
            <i class="fas fa-arrow-left"></i>
            Back
        </a>
    </div>
</div>

<div class="card shadow">
    <div class="row g-0">

        <!-- Car image -->
        <div class="col-md-6 text-center">
            <% if (car.image) { %>
                <img
                    src="<%= car.image %>"
                    class="car-img-detail"
                    alt="<%= car.name %>"
                >
            <% } else { %>
                <img
                    src="https://via.placeholder.com/600x400?text=Car+Image"
                    class="car-img-detail"
                    alt="Car Image"
                >
            <% } %>
        </div>

        <!-- Car information -->
        <div class="col-md-6">
            <div class="card-body">

                <h2 class="card-title">
                    <%= car.name %>
                </h2>

                <p class="text-muted">
                    <%= car.make %> <%= car.model %>
                </p>

                <p class="car-price">
                    $<%= Number(car.price).toLocaleString() %>
                </p>

                <hr>

                <ul class="list-unstyled">
                    <li>
                        <strong>Year:</strong>
                        <%= car.year %>
                    </li>

                    <li>
                        <strong>Color:</strong>
                        <%= car.color %>
                    </li>

                    <li>
                        <strong>Added by:</strong>
                        <%= car.username || 'Unknown' %>
                    </li>

                    <li>
                        <strong>Description:</strong>
                        <br>
                        <%= car.description || 'No description available.' %>
                    </li>
                </ul>

                <!-- WhatsApp contact -->
                <div class="mt-4">
                    <p class="mb-2">
                        <strong>Interested in this car?</strong>
                    </p>

                    <a
                        href="https://wa.me/97685372?text=<%= encodeURIComponent(`Hi, I am interested in the ${car.name} listed on Car Showroom.`) %>"
                        class="btn btn-success btn-lg"
                        target="_blank"
                        rel="noopener noreferrer"
                    >
                        <i class="fab fa-whatsapp"></i>
                        Contact Seller on WhatsApp
                    </a>
                </div>

                <!-- Edit and delete controls -->
                <% if (user) { %>
                    <div class="mt-3">
                        <a
                            href="/edit-car/<%= car.car_id %>"
                            class="btn btn-warning"
                        >
                            Edit
                        </a>

                        <a
                            href="/delete-car/<%= car.car_id %>"
                            class="btn btn-danger"
                            onclick="return confirm('Delete this car?')"
                        >
                            Delete
                        </a>
                    </div>
                <% } %>

            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
