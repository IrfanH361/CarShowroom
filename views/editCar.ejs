<%- include('partials/header') %>

<div class="row justify-content-center mt-4">
    <div class="col-md-7">
        <div class="card shadow">
            <div class="card-header bg-warning">
                <h3><i class="fas fa-edit"></i> Edit Car</h3>
            </div>
            <div class="card-body">
                <% if (error) { %>
                    <div class="alert alert-danger"><%= error %></div>
                <% } %>
                <form action="/edit-car/<%= car.car_id %>" method="POST" enctype="multipart/form-data">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Car Name</label>
                            <input type="text" name="name" class="form-control" value="<%= car.name %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Make</label>
                            <select name="make" class="form-select" required>
                                <option value="Toyota" <%= car.make === 'Toyota' ? 'selected' : '' %>>Toyota</option>
                                <option value="Honda" <%= car.make === 'Honda' ? 'selected' : '' %>>Honda</option>
                                <option value="BMW" <%= car.make === 'BMW' ? 'selected' : '' %>>BMW</option>
                                <option value="Mercedes" <%= car.make === 'Mercedes' ? 'selected' : '' %>>Mercedes</option>
                                <option value="Audi" <%= car.make === 'Audi' ? 'selected' : '' %>>Audi</option>
                                <option value="Porsche" <%= car.make === 'Porsche' ? 'selected' : '' %>>Porsche</option>
                                <option value="Ferrari" <%= car.make === 'Ferrari' ? 'selected' : '' %>>Ferrari</option>
                                <option value="Lamborghini" <%= car.make === 'Lamborghini' ? 'selected' : '' %>>Lamborghini</option>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Model</label>
                            <input type="text" name="model" class="form-control" value="<%= car.model %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Year</label>
                            <select name="year" class="form-select" required>
                                <% for (let y = 2025; y >= 2000; y--) { %>
                                    <option value="<%= y %>" <%= car.year == y ? 'selected' : '' %>><%= y %></option>
                                <% } %>
                            </select>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Color</label>
                            <input type="text" name="color" class="form-control" value="<%= car.color %>" required>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Price ($)</label>
                            <input type="number" name="price" class="form-control" value="<%= car.price %>" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3"><%= car.description %></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Current Image</label><br>
                        <% if (car.image) { %>
                            <img src="/images/<%= car.image %>" width="100" class="rounded"><br>
                        <% } else { %>
                            <p>No image</p>
                        <% } %>
                        <input type="hidden" name="currentImage" value="<%= car.image %>">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Upload New Image (optional)</label>
                        <input type="file" name="image" class="form-control" accept="image/*">
                    </div>
                    <button type="submit" class="btn btn-warning w-100">Update Car</button>
                    <a href="/dashboard" class="btn btn-secondary w-100 mt-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer') %>