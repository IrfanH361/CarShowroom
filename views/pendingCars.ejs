<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-clock"></i> Pending Approvals</h2>
    <span class="badge bg-warning text-dark"><%= cars.length %> pending</span>
</div>

<div class="row">
    <% if (cars && cars.length > 0) { %>
        <% cars.forEach(function(car) { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card car-card h-100">
                    <% if (car.image) { %>
                        <img src="/images/<%= car.image %>" class="car-img" alt="<%= car.name %>">
                    <% } else { %>
                        <img src="https://via.placeholder.com/400x250?text=No+Image" class="car-img" alt="Car Image">
                    <% } %>
                    <div class="card-body">
                        <h5 class="card-title"><%= car.name %></h5>
                        <p class="text-muted"><%= car.make %> <%= car.model %></p>
                        <p class="car-price">$<%= car.price.toLocaleString() %></p>
                        <p class="card-text small">
                            <i class="fas fa-calendar"></i> <%= car.year %> |
                            <i class="fas fa-palette"></i> <%= car.color %>
                        </p>
                        <p class="card-text small">
                            <strong>Seller:</strong> <%= car.username %>
                        </p>
                        <div class="d-flex gap-2 mt-2">
                            <form action="/admin/approve-car/<%= car.car_id %>" method="POST">
                                <button type="submit" class="btn btn-success">
                                    <i class="fas fa-check"></i> Approve
                                </button>
                            </form>
                            <form action="/admin/reject-car/<%= car.car_id %>" method="POST">
                                <button type="submit" class="btn btn-danger">
                                    <i class="fas fa-times"></i> Reject
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12">
            <div class="empty-state">
                <i class="fas fa-check-circle"></i>
                <h3>All Clear!</h3>
                <p>No cars pending approval.</p>
                <a href="/dashboard" class="btn btn-primary mt-3">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>