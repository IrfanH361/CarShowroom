<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-warehouse"></i> My Cars</h2>
    <a href="/add-car" class="btn btn-success"><i class="fas fa-plus"></i> Add Car</a>
</div>

<div class="row">
    <% if (cars && cars.length > 0) { %>
        <% cars.forEach(function(car) { %>
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card car-card h-100">
                    <% if (car.image) { %>
                        <img src="/images/<%= car.image %>" class="car-img" alt="<%= car.name %>">
                    <% } else { %>
                        <img src="https://via.placeholder.com/400x200?text=Car+Image" class="car-img" alt="Car Image">
                    <% } %>
                    <div class="card-body text-center">
                        <h5 class="card-title"><%= car.name %></h5>
                        <p class="text-muted"><%= car.make %> <%= car.model %></p>
                        <p class="car-price">$<%= car.price.toLocaleString() %></p>
                        <div class="btn-group w-100" role="group">
                            <a href="/car/<%= car.car_id %>" class="btn btn-primary btn-sm">View</a>
                            <a href="/edit-car/<%= car.car_id %>" class="btn btn-warning btn-sm">Edit</a>
                            <a href="/delete-car/<%= car.car_id %>" class="btn btn-danger btn-sm" onclick="return confirm('Delete this car?')">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12">
            <div class="empty-state">
                <i class="fas fa-car"></i>
                <h3>No Cars Yet</h3>
                <p>Start building your dream car collection!</p>
                <a href="/add-car" class="btn btn-primary">Add Your First Car</a>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>