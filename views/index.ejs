<%- include('partials/header') %>

<!-- Hero Section -->
<div class="row">
    <div class="col-12">
        <div class="p-5 mb-4 bg-light rounded-3 text-center" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white;">
            <h1 class="display-4"><i class="fas fa-car"></i> Welcome to Car Showroom</h1>
            <p class="lead">Discover, collect, and share your dream cars.</p>
            <% if (!user) { %>
                <a href="/register" class="btn btn-light btn-lg">Get Started</a>
            <% } else { %>
                <a href="/add-car" class="btn btn-light btn-lg">Add Your Dream Car</a>
            <% } %>
        </div>
    </div>
</div>

<!-- Search -->
<div class="row mb-4">
    <div class="col-md-12">
        <form action="/search" method="GET" class="d-flex gap-2 flex-wrap">
            <input type="text" name="query" class="form-control search-box" placeholder="Search by name, make, or model..." value="<%= query %>">
            <select name="make" class="form-select" style="width: 150px;">
                <option value="">All Makes</option>
                <option value="Toyota">Toyota</option>
                <option value="Honda">Honda</option>
                <option value="BMW">BMW</option>
                <option value="Mercedes">Mercedes</option>
                <option value="Audi">Audi</option>
                <option value="Porsche">Porsche</option>
                <option value="Ferrari">Ferrari</option>
                <option value="Lamborghini">Lamborghini</option>
            </select>
            <select name="year" class="form-select" style="width: 120px;">
                <option value="">Year</option>
                <% for (let y = 2025; y >= 2000; y--) { %>
                    <option value="<%= y %>"><%= y %></option>
                <% } %>
            </select>
            <button type="submit" class="btn btn-primary"><i class="fas fa-search"></i> Search</button>
            <a href="/" class="btn btn-secondary">Clear</a>
        </form>
    </div>
</div>

<!-- Cars Grid -->
<div class="row">
    <% if (cars && cars.length > 0) { %>
        <% cars.forEach(function(car) { %>
            <div class="col-md-6 col-lg-3 mb-4">
                <div class="card car-card h-100">
                    <div class="text-center">
                        <% if (car.image) { %>
                            <img src="/images/<%= car.image %>" class="car-img" alt="<%= car.name %>">
                        <% } else { %>
                            <img src="https://via.placeholder.com/400x250?text=Car+Image" class="car-img" alt="Car Image">
                        <% } %>
                    </div>
                    <div class="card-body text-center">
                        <h5 class="card-title"><%= car.name %></h5>
                        <p class="text-muted"><%= car.make %> <%= car.model %></p>
                        <p class="car-price">$<%= car.price.toLocaleString() %></p>
                        <p class="card-text small"><i class="fas fa-calendar"></i> <%= car.year %> | <i class="fas fa-palette"></i> <%= car.color %></p>
                        
                        <!-- ========================================= -->
                        <!-- BUTTONS: View Details + Buy + Favourites -->
                        <!-- ========================================= -->
                        <div class="d-flex justify-content-center gap-2 mt-2">

                            <!-- VIEW DETAILS - Everyone -->
                            <a href="/car/<%= car.car_id %>" class="btn btn-primary">
                                View Details
                            </a>

                            <!-- BUY BUTTON - ONLY FOR USERS -->
                            <% if (user && user.role === 'user') { %>
                                <form action="/buy-car/<%= car.car_id %>" method="POST" onsubmit="return confirm('Are you sure you want to buy this car?')">
                                    <button type="submit" class="btn btn-success">
                                        <i class="fas fa-shopping-cart"></i> Buy
                                    </button>
                                </form>
                            <% } %>

                            <!-- FAVOURITE BUTTON - All logged in users -->
                            <% if (user) { %>
                                <% if (Number(car.is_favorite) === 1) { %>
                                    <form action="/favorite/remove/<%= car.car_id %>" method="POST">
                                        <button type="submit" class="btn btn-danger">
                                            <i class="fas fa-heart"></i>
                                        </button>
                                    </form>
                                <% } else { %>
                                    <form action="/favorite/<%= car.car_id %>" method="POST">
                                        <button type="submit" class="btn btn-outline-danger">
                                            <i class="far fa-heart"></i>
                                        </button>
                                    </form>
                                <% } %>
                            <% } %>

                        </div>
                    </div>
                </div>
            </div>
        <% }); %>
    <% } else { %>
        <div class="col-12">
            <div class="empty-state">
                <i class="fas fa-car"></i>
                <h3>No Cars Found</h3>
                <p>Be the first to add a car to the showroom!</p>
                <% if (user) { %>
                    <a href="/add-car" class="btn btn-primary">Add Your Car</a>
                <% } else { %>
                    <a href="/login" class="btn btn-primary">Login to Add Cars</a>
                <% } %>
            </div>
        </div>
    <% } %>
</div>

<%- include('partials/footer') %>